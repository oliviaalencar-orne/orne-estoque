# ========================================
# Orne Estoque — .env.example
# ========================================
# Copie para .env.local e preencha com os valores reais.
# Valores marcados com "(Vercel auto)" são injetados automaticamente
# em deploys na Vercel — não precisa definir localmente.
#
# IMPORTANTE: para desenvolvimento local, use SEMPRE credenciais de
# STAGING — nunca produção. O cliente Supabase falha alto em runtime
# se estas variáveis estiverem ausentes (sem fallback silencioso).

# Supabase — public client (use credenciais de STAGING em dev local)
VITE_SUPABASE_URL=https://<seu-projeto-staging>.supabase.co
VITE_SUPABASE_ANON_KEY=<sua-chave-anon-staging>

# ========================================
# Sentry (observabilidade — frontend)
# ========================================
# DSN público do projeto React no Sentry
VITE_SENTRY_DSN=

# Variáveis de build, usadas pelo @sentry/vite-plugin para upload de
# source maps e criação de releases. Preenchidas automaticamente pela
# Vercel em Settings → Environment Variables.
# SENTRY_ORG=              # (Vercel) nome da organização
# SENTRY_PROJECT=          # (Vercel) ex: orne-estoque-frontend
# SENTRY_AUTH_TOKEN=       # (Vercel) token com permissão de upload
# VERCEL_GIT_COMMIT_SHA=   # (Vercel auto) SHA do commit → release name
